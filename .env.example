# 체인 연동 환경변수 예시 — 실제 값은 .env 또는 IDE 실행 설정에 넣는다.
# .env 는 git에서 제외됨(.gitignore). 운영 키를 커밋하지 말 것.

# 블록체인 RPC URL (로컬 Anvil 기본)
STO_CHAIN_RPC_URL=http://127.0.0.1:8545

# 계좌관리기관(agent) 서명 개인키.
# 아래 값은 Anvil 0번 계정 — 로컬 개발 전용. 실제 키로 절대 쓰지 말 것.
STO_CHAIN_AGENT_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# 배포된 SecurityToken 컨트랙트 주소 (forge 배포 후 채움)
STO_CHAIN_CONTRACT_ADDRESS=
